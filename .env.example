# SyncPlay configuration overrides
# ===================================================================
# Скопируй в .env (он в .gitignore) и подправь под свои нужды.
# Скрипты в проекте сами .env НЕ читают, но Docker Compose читает,
# а Spring/Node читают process env — поэтому удобно держать здесь.

# --- База данных ---
DB_URL=jdbc:postgresql://localhost:5432/music_streaming
DB_USER=musicapp
DB_PASSWORD=change-me-in-production

# --- MinIO (S3 хранилище) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-in-production
MINIO_BUCKET=syncplay-tracks

# Если MinIO доступен браузеру по другому URL (например LAN IP) —
# Spring будет делать 302 redirect напрямую на MinIO для аудио-стримов,
# минуя proxy. Существенно ускоряет на мобильных и слабых сетях.
# Оставь пустым чтобы стримить через Spring.
MINIO_PUBLIC_ENDPOINT=

# --- Internal API secret ---
# Между Spring и legacy sync-сервером, и для одноразовых WS-токенов.
INTERNAL_SECRET=change-me-in-production

# --- CORS ---
# Comma-separated. LAN-паттерны типа 192.168.x.x:* уже разрешены в application.yml.
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---
# URL Spring как видит его Next.js на этапе SSR / rewrites.
API_URL=http://localhost:8080

# Абсолютный URL WebSocket-эндпоинта syncplay-sync. Когда задан, клиент
# подключается сюда вместо дефолтного ws://<hostname>:3002.
#
# Рекомендованная конфигурация — единый порт через nginx (см. nginx/nginx.conf
# и сервис nginx в docker-compose.yml). Тогда страница и WS живут на одном
# origin, что лечит iOS Safari mixed-content и блокировку нестандартных
# портов мобильными операторами.
#
# Префикс NEXT_PUBLIC_ обязателен — переменная читается клиентским JS на
# этапе сборки Next.js. После изменения нужен `./build.sh next` либо
# `docker compose build next`.
#
# Примеры:
#   NEXT_PUBLIC_SYNC_WS_URL=ws://<LAN-IP-машины>          (dev через nginx)
#   NEXT_PUBLIC_SYNC_WS_URL=wss://syncplay.example.com    (prod через nginx + TLS)
#   NEXT_PUBLIC_SYNC_WS_URL=ws://192.168.1.10:3002        (без nginx, прямо на sync)
NEXT_PUBLIC_SYNC_WS_URL=

# --- Демо-пользователь при первом запуске ---
# Создаётся автоматически если в users пусто. Облегчает onboarding.
DEMO_USER_ENABLED=true
DEMO_USER_USERNAME=demo
DEMO_USER_PASSWORD=demo123
DEMO_USER_EMAIL=demo@syncplay.local
