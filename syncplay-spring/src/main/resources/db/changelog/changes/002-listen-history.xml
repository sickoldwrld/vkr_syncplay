<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-listen-history" author="syncplay">
        <createTable tableName="listen_history">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_history_user"
                    referencedTableName="users" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="track_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_history_track"
                    referencedTableName="tracks" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="room_id" type="UUID">
                <constraints foreignKeyName="fk_history_room"
                    referencedTableName="listening_rooms" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="played_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="duration_ms" type="BIGINT" defaultValueNumeric="0"/>
        </createTable>

        <createIndex tableName="listen_history" indexName="idx_history_user_played">
            <column name="user_id"/>
            <column name="played_at" descending="true"/>
        </createIndex>

        <createIndex tableName="listen_history" indexName="idx_history_track">
            <column name="track_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
